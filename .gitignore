# Data files - keep training data for deployment, ignore processed/outputs
data/processed/*
data/external/*
data/validation/*
!data/processed/.gitkeep
!data/external/.gitkeep
!data/validation/.gitkeep

# Models (large binary files)
models/trained/*.pkl
models/trained/*.joblib
models/trained/*.h5
models/checkpoints/*
models/experimental/*
!models/trained/.gitkeep
!models/checkpoints/.gitkeep
!models/experimental/.gitkeep

# Outputs
outputs/reports/*
outputs/visualizations/*
outputs/predictions/*
outputs/logs/*
!outputs/reports/.gitkeep
!outputs/visualizations/.gitkeep
!outputs/predictions/.gitkeep
!outputs/logs/.gitkeep

