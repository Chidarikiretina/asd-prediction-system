# ============================================================
# ASD Prediction System - Environment Variables
# Copy this file to .env for local development
# On Render, set these in the dashboard or render.yaml
# ============================================================

# Flask secret key (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-secret-key

# Set to "true" in production (Render enforces HTTPS automatically)
SESSION_COOKIE_SECURE=false

# SQLite database path
# Render: /var/data/asd_system.db  (persistent disk)
# Local:  leave blank to use default (data/asd_system.db)
ASD_DB_PATH=

# Email notifications (optional)
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=asd.screening@health.gov.zw
SMTP_SENDER_PASSWORD=
ADMIN_EMAILS=admin@health.gov.zw
